<Window x:Class="ZenTab.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZenTab"
        WindowStyle="None"
        Background="{StaticResource PanelBrush}"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <!-- A floating, content-sized "frosted" card (NOT full-screen). The recede/dim+blur comes
         from the separate DimWindow underneath. The window stays opaque (the two-window
         architecture: the dim layer carries the blur/recede, this panel carries the content);
         corners are rounded at the DWM level (see OverlayWindow.OnSourceInitialized). A faithful
         transcription of the website overlay (website/src/pages/Overlay.tsx), mirroring darwin's
         OverlayTheme.swift.

         Tile previews are cached static window snapshots (WindowService warms them on idle) so a
         card paints its image the instant the panel shows. The index/action chips live in the
         tile footer (always visible). -->

    <Window.Resources>
        <Style x:Key="CardItem" TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Margin" Value="6"/>
            <!-- Hover follows selection; click commits (last input wins, per VISION.md). -->
            <EventSetter Event="MouseEnter" Handler="OnItemMouseEnter"/>
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="OnItemMouseUp"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card"
                                CornerRadius="15"
                                Padding="5"
                                Background="{StaticResource TileFillBrush}"
                                BorderBrush="Transparent"
                                BorderThickness="2">
                            <StackPanel Width="196">
                                <!-- The cached static snapshot (Preview) paints instantly with the
                                     card — idle-warmed by WindowService, so previews never "fill in
                                     late". The placeholder is a near-black so letterbox bars (and
                                     any window that couldn't be captured) recede. -->
                                <Border x:Name="Thumb"
                                        Width="196" Height="120"
                                        CornerRadius="10"
                                        Background="{StaticResource ThumbPlaceholderBrush}"
                                        BorderBrush="{StaticResource ThumbBorderBrush}"
                                        BorderThickness="1"
                                        ClipToBounds="True">
                                    <Image Source="{Binding Preview}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           SnapsToDevicePixels="True"/>
                                </Border>

                                <!-- Footer: index chip · app icon · title · (W / Q when selected). -->
                                <Grid Margin="2,9,2,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 1…9 index chip (jump shortcut). -->
                                    <Border Grid.Column="0"
                                            Width="18" Height="18"
                                            CornerRadius="5"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource IndexChipFillBrush}"
                                            Visibility="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource IndexVis}}">
                                        <TextBlock x:Name="IndexNum"
                                                   Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource IndexText}}"
                                                   Foreground="{StaticResource IndexChipTextBrush}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="10" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Image Grid.Column="1"
                                           Source="{Binding Icon}"
                                           Width="18" Height="18"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           SnapsToDevicePixels="True">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <!-- No icon → collapse so the title shifts left with no gap. -->
                                                    <Trigger Property="Source" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>

                                    <TextBlock x:Name="TitleText"
                                               Grid.Column="2"
                                               Text="{Binding Title}"
                                               Foreground="{StaticResource TitleBrush}"
                                               FontFamily="{StaticResource UiFont}"
                                               FontSize="12.5"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- W closes the window, Q quits the app (VISION.md). Shown on the
                                         selected tile; also discoverable via the footer hint row. -->
                                    <StackPanel x:Name="Actions"
                                                Grid.Column="3"
                                                Orientation="Horizontal"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Visibility="Collapsed">
                                        <Border Width="19" Height="19" CornerRadius="5" Margin="0,0,5,0"
                                                Background="{StaticResource ChipFillBrush}"
                                                BorderBrush="{StaticResource ChipBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="W" Foreground="{StaticResource ChipGlyphBrush}"
                                                       FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Width="19" Height="19" CornerRadius="5"
                                                Background="{StaticResource ChipFillBrush}"
                                                BorderBrush="{StaticResource ChipBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="Q" Foreground="{StaticResource ChipGlyphBrush}"
                                                       FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{StaticResource SelectionWashBrush}"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource SelectionBorderBrush}"/>
                                <Setter TargetName="TitleText" Property="Foreground" Value="{StaticResource TitleSelectedBrush}"/>
                                <Setter TargetName="IndexNum" Property="Foreground" Value="{StaticResource IndexChipTextSelectedBrush}"/>
                                <Setter TargetName="Actions" Property="Visibility" Value="Visible"/>
                                <!-- Soft accent glow lifts the focused tile (website 0 12px 34px accent@0.3). -->
                                <Setter TargetName="Card" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource AccentColor}"
                                                          BlurRadius="22" ShadowDepth="8"
                                                          Direction="270" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- The frosted card. Its content (header / tiles / footer) fades in/out (~60 ms); the
         window background stays opaque (the dim layer behind carries the rest of the recede). -->
    <Border x:Name="Scene"
            CornerRadius="12"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            Padding="22">
        <Grid MinWidth="720">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: key pill · mode label · count. -->
            <Grid Grid.Row="0" Margin="2,0,2,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        CornerRadius="7"
                        BorderBrush="{StaticResource PillBorderBrush}"
                        BorderThickness="1"
                        Padding="9,4"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="KeyPillText"
                               Text="Alt+Tab"
                               Foreground="{StaticResource PillTextBrush}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="12"/>
                </Border>
                <TextBlock x:Name="ModeLabel"
                           Grid.Column="1"
                           Margin="12,0,0,0"
                           Text="Other apps"
                           Foreground="{StaticResource HeaderLabelBrush}"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="CountText"
                           Grid.Column="3"
                           Foreground="{StaticResource CountBrush}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Tiles. -->
            <Grid Grid.Row="1">
                <ListBox x:Name="Cards"
                         HorizontalAlignment="Center"
                         Background="Transparent"
                         BorderThickness="0"
                         Focusable="False"
                         AlternationCount="999"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ItemContainerStyle="{StaticResource CardItem}">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource CalmScrollBar}"/>
                    </ListBox.Resources>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <!-- Deliberate empty state (rare) instead of a tiny blank box. -->
                <TextBlock x:Name="EmptyLabel"
                           Text="Nothing here"
                           Foreground="{StaticResource MutedBrush}"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>

            <!-- Footer hint row. -->
            <Border Grid.Row="2"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,1,0,0"
                    Margin="2,16,2,0"
                    Padding="0,12,0,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Right" FontFamily="{StaticResource MonoFont}" FontSize="11">
                        <Run Foreground="{StaticResource FooterKeyBrush}" Text="Esc"/><Run Foreground="{StaticResource FooterTextBrush}" Text=" cancel"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,16,0" FontFamily="{StaticResource MonoFont}" FontSize="11">
                            <Run Foreground="{StaticResource FooterKeyBrush}" Text="Tab"/><Run Foreground="{StaticResource FooterTextBrush}" Text=" cycle"/>
                        </TextBlock>
                        <TextBlock Margin="0,0,16,0" FontFamily="{StaticResource MonoFont}" FontSize="11">
                            <Run Foreground="{StaticResource FooterKeyBrush}" Text="release"/><Run Foreground="{StaticResource FooterTextBrush}" Text=" switch"/>
                        </TextBlock>
                        <TextBlock Margin="0,0,16,0" FontFamily="{StaticResource MonoFont}" FontSize="11">
                            <Run Foreground="{StaticResource FooterKeyBrush}" Text="W"/><Run Foreground="{StaticResource FooterTextBrush}" Text=" close window"/>
                        </TextBlock>
                        <TextBlock Margin="0,0,16,0" FontFamily="{StaticResource MonoFont}" FontSize="11">
                            <Run Foreground="{StaticResource FooterKeyBrush}" Text="Q"/><Run Foreground="{StaticResource FooterTextBrush}" Text=" quit app"/>
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
