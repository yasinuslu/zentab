# macOS
.DS_Store

# Xcode — user-specific state (the .xcodeproj itself IS committed)
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.moved-aside

# Build products
build/
DerivedData/
*.xcarchive
dist/
*.app
*.dmg
*.zip

# Code coverage artifacts (from running instrumented test binaries)
*.profraw
*.profdata

# Swift Package Manager
.build/
.swiftpm/

# SourceKit-LSP / xcode-build-server (machine-specific; regenerate with bin/setup)
buildServer.json
.compile
.bundle/

# Secrets / signing material — never commit these
*.p12
*.cer
*.mobileprovision
*.provisionprofile
.env
