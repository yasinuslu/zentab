#!/usr/bin/env bash
# Build a Release .app and package it as a branded .dmg and a .zip into dist/.
#
# This mirrors what .github/workflows/darwin-release.yml does in CI. The build is
# ad-hoc signed (CODE_SIGN_IDENTITY="-"), which runs locally but is NOT
# notarized — other Macs will show a Gatekeeper warning. See docs/HUMAN-TODO.md
# to add real Developer ID signing + notarization later.
#
# The DMG is dressed with the brand artwork generated by bin/branding: a custom
# volume icon and a background with a drag-to-Applications layout. The Finder
# layout step needs a GUI session; it's best-effort, so a headless box still
# produces a valid (if plainer) DMG.
source "$(dirname "$0")/lib.sh"

VERSION="${1:-0.1.0}"
echo "Packaging ZenTab $VERSION (Release, ad-hoc signed)..."

rm -rf dist
mkdir -p dist
ARCHIVE="dist/ZenTab.xcarchive"

xcb archive \
  -project "$PROJECT" -scheme "$SCHEME" \
  -configuration Release \
  -destination 'generic/platform=macOS' \
  -archivePath "$ARCHIVE" \
  CODE_SIGN_IDENTITY="-" CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM="" ENABLE_HARDENED_RUNTIME=NO \
  MARKETING_VERSION="$VERSION"

APP="$ARCHIVE/Products/Applications/ZenTab.app"

# --- Branded drag-to-install .dmg -------------------------------------------
# Standard recipe: build a read-write image, dress it on a mounted volume, then
# convert to a compressed read-only image. Uses only built-in macOS tools.
VOL="ZenTab $VERSION"
DMG="dist/ZenTab-$VERSION.dmg"
RW="dist/ZenTab-rw.dmg"
MOUNT="/Volumes/$VOL"
BG_TIFF="branding/dmg/background.tiff"
VOL_ICNS="branding/dmg/VolumeIcon.icns"

# Unmount a stale volume of the same name from a previous interrupted run.
hdiutil detach "$MOUNT" >/dev/null 2>&1 || true

# Size the writable image to the app plus headroom for the dressing.
APP_KB="$(du -sk "$APP" | cut -f1)"
SIZE_MB=$(( APP_KB / 1024 + 60 ))

rm -f "$RW"
hdiutil create -srcfolder "$APP" -volname "$VOL" -fs HFS+ \
  -format UDRW -size "${SIZE_MB}m" "$RW" >/dev/null

DEV="$(hdiutil attach "$RW" -nobrowse -noverify -noautoopen | grep -E '^/dev/' | head -1 | awk '{print $1}')"

# Drop target + background on the mounted volume.
ln -sf /Applications "$MOUNT/Applications"
if [ -f "$BG_TIFF" ]; then
  mkdir -p "$MOUNT/.background"
  cp "$BG_TIFF" "$MOUNT/.background/background.tiff"
fi

# Lay out the Finder window. Best-effort: on a headless box (no Finder/GUI)
# this no-ops and the DMG is still valid, just without the positioned layout.
if [ -f "$BG_TIFF" ]; then
  osascript <<EOF >/dev/null 2>&1 || echo "  note: Finder layout skipped (no GUI session); DMG is still valid."
tell application "Finder"
  tell disk "$VOL"
    open
    set current view of container window to icon view
    set toolbar visible of container window to false
    set statusbar visible of container window to false
    set the bounds of container window to {300, 140, 960, 540}
    set theViewOptions to the icon view options of container window
    set arrangement of theViewOptions to not arranged
    set icon size of theViewOptions to 128
    set text size of theViewOptions to 12
    set background picture of theViewOptions to file ".background:background.tiff"
    set position of item "ZenTab.app" of container window to {165, 170}
    set position of item "Applications" of container window to {495, 170}
    update without registering applications
    delay 1
    close
  end tell
end tell
EOF
fi

# Volume icon LAST: Finder clears the custom-icon flag (and removes
# .VolumeIcon.icns) when it lays the window out, so set it after that step.
if [ -f "$VOL_ICNS" ]; then
  cp "$VOL_ICNS" "$MOUNT/.VolumeIcon.icns"
  xcrun SetFile -a C "$MOUNT" 2>/dev/null || true  # flag the volume as custom-iconned
fi

# Finalize: flush, detach, compress to read-only.
sync
hdiutil detach "$DEV" -force >/dev/null 2>&1 || hdiutil detach "$MOUNT" -force >/dev/null 2>&1 || true
rm -f "$DMG"
hdiutil convert "$RW" -format UDZO -imagekey zlib-level=9 -o "$DMG" >/dev/null
rm -f "$RW"

# --- Plain .zip of the app --------------------------------------------------
( cd "$ARCHIVE/Products/Applications" && zip -r -y -q "$ROOT/dist/ZenTab-$VERSION.zip" ZenTab.app )

echo
echo "Built:"
ls -1 dist/*.dmg dist/*.zip
