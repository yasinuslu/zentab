#!/usr/bin/env bash
# Build (Debug) and launch ZenTab with the SAFE development shortcuts (Ctrl+Opt+…),
# so iterating on the app never hijacks your real Cmd+Tab. Use bin/run-prod to launch
# the production Cmd+Tab suite. A CLI alternative to ⌘R in Xcode.
source "$(dirname "$0")/lib.sh"

build_and_launch -profile dev
