#!/usr/bin/env bash
# Regenerate ZenTab.xcodeproj from project.yml (the source of truth).
# Run this after adding or removing source files, or changing build settings.
# Sources are discovered by directory, so new .swift files need no project edit.
source "$(dirname "$0")/lib.sh"

if ! command -v xcodegen >/dev/null 2>&1; then
  echo "xcodegen not found. Install it with:  brew install xcodegen   (or: brew bundle)" >&2
  exit 1
fi

xcodegen generate --spec project.yml
echo "Regenerated $PROJECT from project.yml."
