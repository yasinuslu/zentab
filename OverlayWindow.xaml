<Window x:Class="ZenTab.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZenTab"
        WindowStyle="None"
        Background="#1E1E2D"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <!-- A floating, content-sized panel (NOT full-screen). The recede/dim comes from the
         separate translucent DimWindow underneath. Opaque so DWM live thumbnails render. -->

    <Window.Resources>
        <Style x:Key="CardItem" TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Margin" Value="6"/>
            <!-- Hover follows selection; click commits (last input wins, per VISION.md). -->
            <EventSetter Event="MouseEnter" Handler="OnItemMouseEnter"/>
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="OnItemMouseUp"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card"
                                CornerRadius="12"
                                Padding="10"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1.5">
                            <StackPanel Width="240">
                                <!-- DWM draws the live thumbnail over this rectangle. -->
                                <Border x:Name="Thumb"
                                        Width="240" Height="150"
                                        CornerRadius="6"
                                        Background="#14FFFFFF"/>
                                <TextBlock Text="{Binding Title}"
                                           Foreground="#CDD6F4"
                                           FontSize="13"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#2ECDD6F4"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#B4B4BEFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Scene fades in/out (~100 ms). -->
    <Grid x:Name="Scene" Margin="22">
        <ListBox x:Name="Cards"
                 Background="Transparent"
                 BorderThickness="0"
                 Focusable="False"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ItemContainerStyle="{StaticResource CardItem}">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Window>
