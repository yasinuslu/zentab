#!/usr/bin/env bash
# Build (Debug) and launch ZenTab with the PRODUCTION shortcut suite: it owns Cmd+Tab
# (other apps), Cmd+` (this app), and Option+Tab (everything), replacing the native
# macOS switchers while it runs — exactly what the shipped app does. The native
# shortcuts are handed back when ZenTab quits (and restored if it's killed/crashes).
#
# Watch the menu bar icon: a calm rectangle means ZenTab owns the shortcut; a warning
# triangle means it doesn't (open the menu for why). Needs Accessibility permission.
source "$(dirname "$0")/lib.sh"

build_and_launch -profile production
